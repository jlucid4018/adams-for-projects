+from __future__ import annotations
+
+import datetime as _dt
+import json
+import socket
+from concurrent.futures import ThreadPoolExecutor, TimeoutError as FuturesTimeout
+from typing import Any, Dict, List, Optional, Tuple
+
+import requests
+
+APS_SEARCH_URL = "https://adams-api.nrc.gov/aps/api/search"
+DEFAULT_PAGE_SIZE = 100
+
+
+class APSClientError(RuntimeError):
+    pass
+
+
+def _resolve_host_with_timeout(host: str, timeout_s: float = 5.0) -> None:
+    """
+    Fail fast if DNS resolution hangs (requests timeouts don't cover getaddrinfo).
+    """
+    def _do():
+        socket.getaddrinfo(host, 443, proto=socket.IPPROTO_TCP)
+        return True
+
+    with ThreadPoolExecutor(max_workers=1) as ex:
+        fut = ex.submit(_do)
+        try:
+            fut.result(timeout=timeout_s)
+        except FuturesTimeout:
+            raise APSClientError(f"DNS resolution timed out for host '{host}' after {timeout_s:.1f}s")
+
+
+def _next_day(day: _dt.date) -> _dt.date:
+    return day + _dt.timedelta(days=1)
+
+
+class APSClient:
+    """
+    Client for the APS (ADAMS Public Search) API.
+    Your tenant returns: {count, results:[{document:{...}}], facets, pageNumber}
+    """
+    def __init__(self, api_key: str, debug: bool = False, base_url: str = APS_SEARCH_URL):
+        self.api_key = api_key
+        self.debug = debug
+        self.base_url = base_url
+        self._session = requests.Session()
+        self._headers = {
+            "Accept": "application/json",
+            "Content-Type": "application/json",
+            "Ocp-Apim-Subscription-Key": api_key,
+            "Cache-Control": "no-cache",
+        }
+
+        host = requests.utils.urlparse(self.base_url).hostname or ""
+        if host:
+            _resolve_host_with_timeout(host, timeout_s=5.0)
+
+    def _dump_last(self, body: Dict[str, Any], resp: requests.Response) -> None:
+        # Write locally so you don't have to paste anything back.
+        try:
+            with open(".adamsfp_last_request.json", "w", encoding="utf-8") as f:
+                json.dump(body, f, indent=2, ensure_ascii=False)
+            with open(".adamsfp_last_response.txt", "w", encoding="utf-8") as f:
+                f.write(resp.text or "")
+        except Exception:
+            pass
+
+    def _post(self, body: Dict[str, Any]) -> Dict[str, Any]:
+        resp = self._session.post(
+            self.base_url,
+            headers=self._headers,
+            json=body,
+            timeout=(5, 20),  # connect/read timeouts; DNS handled separately
+        )
+
+        if self.debug:
+            print("[debug] POST", self.base_url)
+            print("[debug] HTTP", resp.status_code)
+
+        if resp.status_code >= 400:
+            self._dump_last(body, resp)
+
+        resp.raise_for_status()
+        return resp.json()
+
+    @staticmethod
+    def extract_docs(payload: Dict[str, Any]) -> Tuple[int, List[Dict[str, Any]], Optional[int]]:
+        """
+        Returns (count, docs, pageNumber).
+        Supports schema:
+          - {count:int, results:[{document:{...}}], pageNumber:int}
+          - fallback legacy keys if they ever appear
+        """
+        count = payload.get("count") if isinstance(payload.get("count"), int) else None
+        page_num = payload.get("pageNumber") if isinstance(payload.get("pageNumber"), int) else None
+
+        if isinstance(payload.get("results"), list):
+            docs: List[Dict[str, Any]] = []
+            for it in payload["results"]:
+                if isinstance(it, dict) and isinstance(it.get("document"), dict):
+                    docs.append(it["document"])
+            return (count or len(docs), docs, page_num)
+
+        # fallback legacy list keys
+        for key in ("Documents", "documents", "Results", "results", "items"):
+            if isinstance(payload.get(key), list):
+                docs = payload[key]
+                total = None
+                for tkey in ("total", "Total", "totalCount", "TotalCount", "count", "Count"):
+                    if isinstance(payload.get(tkey), int):
+                        total = payload[tkey]
+                        break
+                return (total or len(docs), docs, page_num)
+
+        return (count or 0, [], page_num)
+
+    def search_date_added(self, day: _dt.date, page_number: int = 1, page_size: int = DEFAULT_PAGE_SIZE) -> Dict[str, Any]:
+        """
+        Query docs added on a given date. Tries multiple payload variants because
+        tenants differ. On errors, last request/response are written to disk.
+        """
+        d0 = day.strftime("%Y-%m-%d")
+        d1 = _next_day(day).strftime("%Y-%m-%d")
+
+        candidates: List[Dict[str, Any]] = [
+            # Candidate 1: pageNumber/pageSize + string filters (most likely for your schema)
+            {
+                "q": "",
+                "pageNumber": page_number,
+                "pageSize": page_size,
+                "filters": [
+                    f"DateAddedTimestamp ge '{d0}'",
+                    f"DateAddedTimestamp lt '{d1}'",
+                ],
+                "sort": "DateAddedTimestamp",
+                "sortDirection": -1,
+            },
+            # Candidate 2: same but wrapped in parentheses
+            {
+                "q": "",
+                "pageNumber": page_number,
+                "pageSize": page_size,
+                "filters": [
+                    f"(DateAddedTimestamp ge '{d0}')",
+                    f"(DateAddedTimestamp lt '{d1}')",
+                ],
+                "sort": "DateAddedTimestamp",
+                "sortDirection": -1,
+            },
+            # Candidate 3: older guide-style objects + skip
+            {
+                "q": "",
+                "filters": [
+                    {"field": "DateAddedTimestamp", "value": f"(DateAddedTimestamp ge '{d0}')"},
+                    {"field": "DateAddedTimestamp", "value": f"(DateAddedTimestamp lt '{d1}')"},
+                ],
+                "anyFilters": [],
+                "mainLibFilter": True,
+                "legacyLibFilter": False,
+                "sort": "DateAddedTimestamp",
+                "sortDirection": -1,
+                "skip": (page_number - 1) * page_size,
+            },
+        ]
+
+        last_err: Optional[Exception] = None
+        for idx, body in enumerate(candidates, start=1):
+            try:
+                if self.debug:
+                    print(f"[debug] Trying payload candidate {idx}")
+                payload = self._post(body)
+                count, docs, _pn = self.extract_docs(payload)
+
+                # If we get millions back, the filter was ignored. Try next candidate.
+                if count and count > 100000 and idx < len(candidates):
+                    if self.debug:
+                        print(f"[debug] Candidate {idx} returned huge count={count}; assuming filter ignored.")
+                    continue
+
+                return payload
+            except Exception as e:
+                last_err = e
+                if self.debug:
+                    print(f"[debug] Candidate {idx} failed: {e}")
+                continue
+
+        raise APSClientError(
+            "APS search failed after trying payload variants. "
+            f"Last error: {last_err}. "
+            "See .adamsfp_last_request.json / .adamsfp_last_response.txt."
+        )
