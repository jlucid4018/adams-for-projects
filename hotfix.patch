 def cmd_run(args) -> int:
     day = _parse_date(args)
     max_pages = args.max_pages
     top_n = args.top
     print(f"[+] Querying APS for documents added on {day} (max_pages={max_pages}) ...")
 
     try:
         client = APSClient(args.key, debug=args.debug)
     except APSClientError as e:
         print(f"[!] ERROR: {e}")
         return 2
 
     all_docs: List[Dict[str, Any]] = []
     page_number = 1
     total_count = None
 
     while page_number <= max_pages:
         if args.debug:
             print(f"[debug] Fetching pageNumber={page_number}")
         try:
             payload = client.search_date_added(day, page_number=page_number, page_size=100)
         except APSClientError as e:
             print(f"[!] ERROR: {e}")
             break
 
         count, docs, pn = _extract_docs(payload)
         total_count = count if total_count is None else total_count
         if not docs:
             break
         all_docs.extend(docs)
         page_number += 1
         if len(docs) < 100:
             break
 
     cache_dir = ensure_cache_dir("cache")
     cache_path = cache_dir / f"{day}.json"
     save_json(cache_path, {"date": str(day), "docs": all_docs})
     print(f"[+] Retrieved {len(all_docs)} docs (count_field={total_count}). Cached to {cache_path}")
 
     scored = []
     for d in all_docs:
         title = _doc_title(d)
         if not title:
             continue
         if is_noise(title):
             continue
         score, hits = score_title(title)
         scored.append((score, hits, d))
 
     scored.sort(key=lambda x: x[0], reverse=True)
     top = scored[:top_n]
 
     print(f"\nTop {top_n} picks:")
     for score, hits, d in top:
         acc = _doc_accession(d)
         title = _doc_title(d)
         print(f"[{score:>3}] {acc} | {title}")
         if hits:
             print(f"     hits: {hits}")
     return 0
 
 def build_parser() -> argparse.ArgumentParser:
     p = argparse.ArgumentParser(prog="adams", description="ADAMS for Projects: daily APS scanner")
     p.add_argument("--key", default=os.environ.get("APS_KEY", ""), help="APS subscription key (or set APS_KEY env var)")
     p.add_argument("--today", action="store_true", help="Use today's date")
     p.add_argument("--date", help="Use a specific date YYYY-MM-DD")
     p.add_argument("--top", type=int, default=5, help="How many top items to display")
     p.add_argument("--max-pages", type=int, default=5, help="Safety cap on pages fetched (page size=100)")
     p.add_argument("--debug", action="store_true", help="Verbose debug output")
     sub = p.add_subparsers(dest="cmd", required=True)
 
     sp = sub.add_parser("probe", help="Probe APS response schema for the selected date")
     sp.set_defaults(func=cmd_probe)
 
     sr = sub.add_parser("run", help="Fetch and rank today's docs")
     sr.set_defaults(func=cmd_run)
 
     return p
 
 def main(argv=None) -> None:
     parser = build_parser()
     args = parser.parse_args(argv)
     if not args.key:
         raise SystemExit("No APS key provided. Set APS_KEY env var or pass --key.")
     rc = args.func(args)
     raise SystemExit(rc)
